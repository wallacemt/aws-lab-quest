// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserAccessStatus {
  pending
  approved
  rejected
}

// ─── Better Auth required tables ──────────────────────────────────────────────

model User {
  id                   String           @id @default(cuid())
  name                 String
  email                String           @unique
  username             String?          @unique
  role                 String           @default("user")
  accessStatus         UserAccessStatus @default(pending)
  active               Boolean          @default(true)
  accessDecisionAt     DateTime?
  accessDecisionReason String?
  lastSeen             DateTime         @default(now())
  emailVerified        Boolean          @default(false)
  image                String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  sessions      Session[]
  accounts      Account[]
  profile       UserProfile?
  questHistory  QuestHistory[]
  studyHistory  StudySessionHistory[]
  userBadges    UserBadge[]
  achievements  UserAchievement[]
  uploadedFiles AdminUploadedFile[]
  ingestionJobs AdminIngestionJob[]

  @@index([accessStatus, active])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ─── App custom tables ─────────────────────────────────────────────────────────

model UserProfile {
  id                    String               @id @default(cuid())
  userId                String               @unique
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  certification         String               @default("")
  certificationPresetId String?
  certificationPreset   CertificationPreset? @relation(fields: [certificationPresetId], references: [id], onDelete: SetNull)
  favoriteTheme         String               @default("")
  avatarUrl             String?
}

model CertificationPreset {
  id            String              @id @default(cuid())
  code          String              @unique
  name          String
  description   String
  examGuide     String?
  examMinutes   Int                 @default(90)
  active        Boolean             @default(true)
  displayOrder  Int                 @default(0)
  userProfiles  UserProfile[]
  questions     StudyQuestion[]
  uploadedFiles AdminUploadedFile[]
  ingestionJobs AdminIngestionJob[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model AwsService {
  id                  String               @id @default(cuid())
  code                String               @unique
  name                String
  description         String?
  active              Boolean              @default(true)
  questions           StudyQuestion[]
  questionAwsServices QuestionAwsService[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

enum StudyQuestionUsage {
  KC
  SIMULADO
  BOTH
}

enum StudyQuestionDifficulty {
  easy
  medium
  hard
}

enum StudyQuestionType {
  single
  multi
}

enum StudySessionType {
  KC
  SIMULADO
}

enum AdminUploadType {
  EXAM_GUIDE
  SIMULADO_PDF
  SIMULADO_GENERATION
}

enum AdminIngestionStatus {
  PENDING
  UPLOADING
  EXTRACTING
  GENERATING
  SAVING
  COMPLETED
  FAILED
}

model StudyQuestion {
  id                    String                  @id @default(cuid())
  externalId            String                  @unique
  statement             String
  usage                 StudyQuestionUsage      @default(BOTH)
  difficulty            StudyQuestionDifficulty @default(medium)
  questionType          StudyQuestionType       @default(single)
  topic                 String
  optionA               String
  optionB               String
  optionC               String
  optionD               String
  optionE               String?
  correctOption         String
  correctOptions        Json?
  explanationA          String?
  explanationB          String?
  explanationC          String?
  explanationD          String?
  explanationE          String?
  cachedExplainSummary  String?
  cachedExplainA        String?
  cachedExplainB        String?
  cachedExplainC        String?
  cachedExplainD        String?
  cachedExplainE        String?
  cachedExplainAt       DateTime?
  cachedExplainVersion  Int                     @default(1)
  rawText               String?
  ingestionVersion      Int                     @default(1)
  usageHash             String?                 @unique
  active                Boolean                 @default(true)
  certificationPresetId String?
  certificationPreset   CertificationPreset?    @relation(fields: [certificationPresetId], references: [id], onDelete: SetNull)
  awsServiceId          String?
  awsService            AwsService?             @relation(fields: [awsServiceId], references: [id], onDelete: SetNull)
  sourceUploadedFileId  String?
  sourceUploadedFile    AdminUploadedFile?      @relation(fields: [sourceUploadedFileId], references: [id], onDelete: SetNull)
  questionOptions       QuestionOption[]
  questionAwsServices   QuestionAwsService[]
  questionTopics        QuestionTopic[]
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([usage, active])
  @@index([difficulty, active])
  @@index([questionType, active])
  @@index([certificationPresetId])
  @@index([awsServiceId])
  @@index([sourceUploadedFileId])
  @@index([cachedExplainAt])
  @@index([usageHash])
}

model QuestionOption {
  id          String        @id @default(cuid())
  questionId  String
  question    StudyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  content     String
  isCorrect   Boolean       @default(false)
  order       Int
  explanation String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([questionId, order])
  @@index([questionId, isCorrect])
}

model Topic {
  id             String          @id @default(cuid())
  name           String          @unique
  questionTopics QuestionTopic[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model QuestionAwsService {
  questionId String
  serviceId  String
  question   StudyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  service    AwsService    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())

  @@id([questionId, serviceId])
  @@index([serviceId])
}

model QuestionTopic {
  questionId String
  topicId    String
  question   StudyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  topic      Topic         @relation(fields: [topicId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())

  @@id([questionId, topicId])
  @@index([topicId])
}

model StudySessionHistory {
  id                String           @id @default(cuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionType       StudySessionType
  title             String
  certificationCode String?
  gainedXp          Int              @default(0)
  scorePercent      Int
  correctAnswers    Int
  totalQuestions    Int
  durationSeconds   Int?
  answersSnapshot   Json
  completedAt       DateTime
  createdAt         DateTime         @default(now())

  @@index([userId, completedAt])
  @@index([sessionType])
}

model QuestHistory {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  theme         String
  xp            Int
  tasksCount    Int
  taskSnapshot  Json?
  sourceLabText String?
  completedAt   DateTime
  certification String   @default("")
  userName      String   @default("")
  createdAt     DateTime @default(now())
}

model LevelBadge {
  id           String      @id @default(cuid())
  level        Int         @unique
  name         String
  imageUrl     String
  supabasePath String
  userBadges   UserBadge[]
}

model UserBadge {
  id       String     @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime   @default(now())
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    LevelBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
}

model Achievement {
  id               String            @id @default(cuid())
  code             String            @unique
  name             String
  description      String
  rarity           String            @default("common")
  imageUrl         String?
  supabasePath     String?
  generationPrompt String?
  active           Boolean           @default(true)
  displayOrder     Int               @default(0)
  userAchievements UserAchievement[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  progress      Int         @default(0)
  metadata      Json?
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
}

model XpWeightConfig {
  id           String   @id @default(cuid())
  activityType String
  topic        String   @default("*")
  difficulty   String   @default("*")
  multiplier   Float    @default(1)
  bonusXp      Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([activityType, topic, difficulty])
  @@index([activityType, active])
}

model AdminUploadedFile {
  id                    String               @id @default(cuid())
  uploadType            AdminUploadType
  certificationPresetId String?
  certificationPreset   CertificationPreset? @relation(fields: [certificationPresetId], references: [id], onDelete: SetNull)
  uploadedByUserId      String?
  uploadedBy            User?                @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  fileName              String
  mimeType              String
  fileSizeBytes         Int
  storageBucket         String
  storagePath           String
  sha256                String
  source                String               @default("admin")
  metadata              Json?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  ingestionJobs         AdminIngestionJob[]
  generatedQuestions    StudyQuestion[]

  @@unique([storageBucket, storagePath])
  @@index([uploadType, createdAt])
  @@index([certificationPresetId, uploadType, createdAt])
  @@index([uploadedByUserId, createdAt])
  @@index([sha256])
}

model AdminIngestionJob {
  id                    String               @id @default(cuid())
  status                AdminIngestionStatus @default(PENDING)
  uploadType            AdminUploadType
  certificationPresetId String?
  certificationPreset   CertificationPreset? @relation(fields: [certificationPresetId], references: [id], onDelete: SetNull)
  createdByUserId       String?
  createdBy             User?                @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  uploadedFileId        String?
  uploadedFile          AdminUploadedFile?   @relation(fields: [uploadedFileId], references: [id], onDelete: SetNull)
  fileName              String?
  progressPercent       Int                  @default(0)
  message               String?
  desiredCount          Int?
  generatedCount        Int?
  savedCount            Int?
  errorMessage          String?
  startedAt             DateTime?
  finishedAt            DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([status, createdAt])
  @@index([uploadType, createdAt])
  @@index([certificationPresetId, createdAt])
  @@index([createdByUserId, createdAt])
  @@index([uploadedFileId])
}

model AdminEmailTemplate {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  description     String?
  subject         String
  html            String
  text            String?
  active          Boolean  @default(true)
  isSystem        Boolean  @default(false)
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([active, updatedAt])
  @@index([isSystem, updatedAt])
}
