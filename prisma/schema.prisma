// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Better Auth required tables ──────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  username      String?  @unique
  role          String   @default("user")
  lastSeen      DateTime @default(now())
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions     Session[]
  accounts     Account[]
  profile      UserProfile?
  questHistory QuestHistory[]
  studyHistory StudySessionHistory[]
  userBadges   UserBadge[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ─── App custom tables ─────────────────────────────────────────────────────────

model UserProfile {
  id                    String               @id @default(cuid())
  userId                String               @unique
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  certification         String               @default("")
  certificationPresetId String?
  certificationPreset   CertificationPreset? @relation(fields: [certificationPresetId], references: [id], onDelete: SetNull)
  favoriteTheme         String               @default("")
  avatarUrl             String?
}

model CertificationPreset {
  id           String          @id @default(cuid())
  code         String          @unique
  name         String
  description  String
  examMinutes  Int             @default(90)
  active       Boolean         @default(true)
  displayOrder Int             @default(0)
  userProfiles UserProfile[]
  questions    StudyQuestion[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model AwsService {
  id          String          @id @default(cuid())
  code        String          @unique
  name        String
  description String?
  active      Boolean         @default(true)
  questions   StudyQuestion[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum StudyQuestionUsage {
  KC
  SIMULADO
  BOTH
}

enum StudyQuestionDifficulty {
  easy
  medium
  hard
}

enum StudySessionType {
  KC
  SIMULADO
}

model StudyQuestion {
  id                    String                  @id @default(cuid())
  externalId            String                  @unique
  statement             String
  usage                 StudyQuestionUsage      @default(BOTH)
  difficulty            StudyQuestionDifficulty @default(medium)
  topic                 String
  optionA               String
  optionB               String
  optionC               String
  optionD               String
  optionE               String?
  correctOption         String
  explanationA          String?
  explanationB          String?
  explanationC          String?
  explanationD          String?
  explanationE          String?
  cachedExplainSummary  String?
  cachedExplainA        String?
  cachedExplainB        String?
  cachedExplainC        String?
  cachedExplainD        String?
  cachedExplainE        String?
  cachedExplainAt       DateTime?
  cachedExplainVersion  Int                     @default(1)
  active                Boolean                 @default(true)
  certificationPresetId String?
  certificationPreset   CertificationPreset?    @relation(fields: [certificationPresetId], references: [id], onDelete: SetNull)
  awsServiceId          String?
  awsService            AwsService?             @relation(fields: [awsServiceId], references: [id], onDelete: SetNull)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([usage, active])
  @@index([difficulty, active])
  @@index([certificationPresetId])
  @@index([awsServiceId])
  @@index([cachedExplainAt])
}

model StudySessionHistory {
  id                String           @id @default(cuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionType       StudySessionType
  title             String
  certificationCode String?
  gainedXp          Int              @default(0)
  scorePercent      Int
  correctAnswers    Int
  totalQuestions    Int
  durationSeconds   Int?
  answersSnapshot   Json
  completedAt       DateTime
  createdAt         DateTime         @default(now())

  @@index([userId, completedAt])
  @@index([sessionType])
}

model QuestHistory {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  theme         String
  xp            Int
  tasksCount    Int
  taskSnapshot  Json?
  sourceLabText String?
  completedAt   DateTime
  certification String   @default("")
  userName      String   @default("")
  createdAt     DateTime @default(now())
}

model LevelBadge {
  id           String      @id @default(cuid())
  level        Int         @unique
  name         String
  imageUrl     String
  supabasePath String
  userBadges   UserBadge[]
}

model UserBadge {
  id       String     @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime   @default(now())
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    LevelBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
}
