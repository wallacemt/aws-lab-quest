# ─── Banco de Dados ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://awlq_user:awlq_pass@localhost:5432/awlq

# ─── Redis (BullMQ) ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Autenticação (Better Auth) ───────────────────────────────────────────────
# Gere com: openssl rand -base64 32
BETTER_AUTH_SECRET=change_this_to_a_random_32_char_secret_minimum
BETTER_AUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_OCR_MODEL=gemini-2.5-flash
# Controle de rate limit (tokens por minuto e intervalo mínimo entre chamadas)
GEMINI_SAFE_TOKENS_PER_MINUTE=9000
GEMINI_MIN_CALL_INTERVAL_MS=2500

# ─── Supabase (Storage + Realtime) ───────────────────────────────────────────
# Obtenha em: https://app.supabase.com → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_jwt_here
SUPABASE_ANON_KEY=your_anon_jwt_here

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# App Password: https://myaccount.google.com/apppasswords
EMAIL_FROM=AWS Quest <noreply@example.com>
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password_here

# ─── Imagens (Pollinations) ───────────────────────────────────────────────────
# Opcional — usado para gerar artes de badges e conquistas
POLLINATIONS_API_KEY=

# ─── Admin Inicial (usado apenas no seed) ────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_strong_password
ADMIN_NAME=Lab Quest Admin

# ─── Worker (apenas awlq-worker) ─────────────────────────────────────────────
# Taxa mínima de acerto para classificar área como fraca (0.0 – 1.0)
WEAK_AREA_THRESHOLD=0.60
# Janela de dias para análise de áreas fracas
WEAK_AREA_WINDOW_DAYS=30
# Intervalo entre ciclos do poller de triggers (ms)
TRIGGER_POLL_INTERVAL_MS=30000
# Nível de log: trace | debug | info | warn | error
LOG_LEVEL=info
# Concorrência máxima do pool de conexões ao banco
DATABASE_POOL_MAX=3
DATABASE_POOL_IDLE_TIMEOUT_MS=30000
DATABASE_POOL_CONNECTION_TIMEOUT_MS=10000
