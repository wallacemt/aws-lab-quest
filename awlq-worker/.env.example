# Database (same PostgreSQL used by aws-lab-quest-next)
DATABASE_URL=postgresql://awlq_user:awlq_pass@localhost:5432/awlq
DATABASE_POOL_MAX=3

# Redis (existing Redis on VPS)
REDIS_URL=redis://localhost:6379

# OpenRouter AI
# Opcional — fallback para a chave configurada pelo Admin no banco
# Obtenha em: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Modelo padrão (usa roteamento automático se não configurado pelo Admin)
AI_MODEL=openrouter/free
# Chave AES-256-GCM (mesma do app) para descriptografar a chave do banco
# Gere com: openssl rand -hex 32
ENCRYPTION_KEY=your_32_byte_hex_key_here
# Rate limit — intervalo mínimo entre chamadas ao OpenRouter (ms)
AI_MIN_CALL_INTERVAL_MS=2500

# Worker config
LOG_LEVEL=info
WEAK_AREA_THRESHOLD=0.60
WEAK_AREA_WINDOW_DAYS=30

# Email (Gmail SMTP — use App Password if 2FA is enabled)
# Generate App Password at: https://myaccount.google.com/apppasswords
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
EMAIL_FROM=AWS Quest <your_email@gmail.com>

# URL base do app — usada nos links CTA dos emails enviados pelo worker
APP_URL=https://awslabquest.com
