# Database (same PostgreSQL used by aws-lab-quest-next)
DATABASE_URL=postgresql://awlq_user:awlq_pass@localhost:5432/awlq
DATABASE_POOL_MAX=3

# Redis (existing Redis on VPS)
REDIS_URL=redis://localhost:6379

# Google Gemini
GEMINI_API_KEY=your-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_SAFE_TOKENS_PER_MINUTE=9000
GEMINI_MIN_CALL_INTERVAL_MS=2500

# Worker config
LOG_LEVEL=info
WEAK_AREA_THRESHOLD=0.60
WEAK_AREA_WINDOW_DAYS=30

# Email (Gmail SMTP — use App Password if 2FA is enabled)
# Generate App Password at: https://myaccount.google.com/apppasswords
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
EMAIL_FROM=AWS Quest <your_email@gmail.com>
