// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum UserAccessStatus {
  pending
  approved
  rejected
}

// ─── Better Auth required tables ──────────────────────────────────────────────

model User {
  id                   String           @id @default(cuid())
  name                 String
  email                String           @unique
  username             String?          @unique
  role                 String           @default("user")
  accessStatus         UserAccessStatus @default(pending)
  active               Boolean          @default(true)
  accessDecisionAt     DateTime?
  accessDecisionReason String?
  lastSeen             DateTime         @default(now())
  emailVerified        Boolean          @default(false)
  image                String?
  emailNotifications   Boolean          @default(true)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  sessions                Session[]
  accounts                Account[]
  profile                 UserProfile?
  questHistory            QuestHistory[]
  studyHistory            StudySessionHistory[]
  userBadges              UserBadge[]
  achievements            UserAchievement[]
  uploadedFiles           AdminUploadedFile[]
  ingestionJobs           AdminIngestionJob[]
  questionReports         QuestionReport[]       @relation("QuestionReportAuthor")
  reviewedQuestionReports QuestionReport[]       @relation("QuestionReportReviewer")
  certBadges              UserCertBadge[]
  simuladoPacks           SimuladoPack[]
  emailEvents             UserEmailEvent[]
  behaviorProfile         UserBehaviorProfile?
  flashcards              Flashcard[]
  falseBeliefSignals      FalseBeliefSignal[]
  mentorRecommendations   MentorRecommendation[]
  questChainProgress      QuestChainProgress[]
  bossBattles             BossBattle[]
  weeklyChallengeEntries  WeeklyChallengeEntry[]
  dailyQuizAttempts       DailyQuizAttempt[]

  @@index([accessStatus, active])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ─── App custom tables ─────────────────────────────────────────────────────────

model UserProfile {
  id                    String               @id @default(cuid())
  userId                String               @unique
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  certification         String               @default("")
  certificationPresetId String?
  certificationPreset   CertificationPreset? @relation(fields: [certificationPresetId], references: [id], onDelete: SetNull)
  favoriteTheme         String               @default("")
  avatarUrl             String?
  bgImageUrl            String?
  themePreset           String?              @default("default")
  leaderboardVisible    Boolean              @default(true)
  targetExamDate        DateTime?
}

model CertificationPreset {
  id               String                @id @default(cuid())
  code             String                @unique
  name             String
  description      String
  examGuide        String?
  examMinutes      Int                   @default(90)
  active           Boolean               @default(true)
  displayOrder     Int                   @default(0)
  userProfiles     UserProfile[]
  questions        StudyQuestion[]
  uploadedFiles    AdminUploadedFile[]
  ingestionJobs    AdminIngestionJob[]
  ingestionSources IngestionSource[]
  blueprintDomains ExamBlueprintDomain[]
  weakAreaReports  WeakAreaReport[]
  certBadges       UserCertBadge[]
  simuladoPacks    SimuladoPack[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}

model AwsService {
  id                  String               @id @default(cuid())
  code                String               @unique
  name                String
  description         String?
  active              Boolean              @default(true)
  questions           StudyQuestion[]
  questionAwsServices QuestionAwsService[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

enum StudyQuestionUsage {
  KC
  SIMULADO
  BOTH
}

enum StudyQuestionDifficulty {
  easy
  medium
  hard
  nightmare
}

enum StudyQuestionType {
  single
  multi
}

enum StudySessionType {
  KC
  SIMULADO
}

enum QuestionReportStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum QuestionReportReason {
  INCORRECT_ANSWER
  UNCLEAR_STATEMENT
  MISSING_CONTEXT
  GRAMMAR_TYPO
  DUPLICATE
  QUALITY_ISSUE
  OTHER
}

enum AdminUploadType {
  EXAM_GUIDE
  SIMULADO_PDF
  SIMULADO_GENERATION
}

enum AdminIngestionStatus {
  PENDING
  UPLOADING
  EXTRACTING
  GENERATING
  SAVING
  COMPLETED
  FAILED
}

model StudyQuestion {
  id                    String                  @id @default(cuid())
  externalId            String                  @unique
  statement             String
  usage                 StudyQuestionUsage      @default(BOTH)
  difficulty            StudyQuestionDifficulty @default(medium)
  questionType          StudyQuestionType       @default(single)
  topic                 String
  optionA               String
  optionB               String
  optionC               String
  optionD               String
  optionE               String?
  correctOption         String
  correctOptions        Json?
  explanationA          String?
  explanationB          String?
  explanationC          String?
  explanationD          String?
  explanationE          String?
  cachedExplainSummary  String?
  cachedExplainA        String?
  cachedExplainB        String?
  cachedExplainC        String?
  cachedExplainD        String?
  cachedExplainE        String?
  cachedExplainAt       DateTime?
  cachedExplainVersion  Int                     @default(1)
  rawText               String?
  ingestionVersion      Int                     @default(1)
  usageHash             String?                 @unique
  active                Boolean                 @default(true)
  certificationPresetId String?
  certificationPreset   CertificationPreset?    @relation(fields: [certificationPresetId], references: [id], onDelete: SetNull)
  awsServiceId          String?
  awsService            AwsService?             @relation(fields: [awsServiceId], references: [id], onDelete: SetNull)
  sourceUploadedFileId  String?
  sourceUploadedFile    AdminUploadedFile?      @relation(fields: [sourceUploadedFileId], references: [id], onDelete: SetNull)
  flaggedAt             DateTime?
  flaggedReason         String?
  questionOptions       QuestionOption[]
  questionAwsServices   QuestionAwsService[]
  questionTopics        QuestionTopic[]
  questionReports       QuestionReport[]
  performance           QuestionPerformance?
  packQuestions         SimuladoPackQuestion[]
  flashcards            Flashcard[]
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([usage, active])
  @@index([difficulty, active])
  @@index([questionType, active])
  @@index([certificationPresetId])
  @@index([awsServiceId])
  @@index([sourceUploadedFileId])
  @@index([cachedExplainAt])
  @@index([usageHash])
  @@index([flaggedAt])
}

model QuestionOption {
  id          String        @id @default(cuid())
  questionId  String
  question    StudyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  content     String
  isCorrect   Boolean       @default(false)
  order       Int
  explanation String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([questionId, order])
  @@index([questionId, isCorrect])
}

model Topic {
  id             String          @id @default(cuid())
  name           String          @unique
  questionTopics QuestionTopic[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model QuestionAwsService {
  questionId String
  serviceId  String
  question   StudyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  service    AwsService    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())

  @@id([questionId, serviceId])
  @@index([serviceId])
}

model QuestionTopic {
  questionId String
  topicId    String
  question   StudyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  topic      Topic         @relation(fields: [topicId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())

  @@id([questionId, topicId])
  @@index([topicId])
}

model StudySessionHistory {
  id                String           @id @default(cuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionType       StudySessionType
  title             String
  certificationCode String?
  gainedXp          Int              @default(0)
  scorePercent      Int
  correctAnswers    Int
  totalQuestions    Int
  durationSeconds   Int?
  answersSnapshot   Json
  completedAt       DateTime
  createdAt         DateTime         @default(now())
  // LGPD retention: set to true when session is older than the retention window.
  // userId is preserved (FK cannot be nulled) but the record is excluded from
  // any user-facing queries so no PII is exposed post-anonymization.
  anonymized        Boolean          @default(false)
  packId            String?
  pack              SimuladoPack?    @relation(fields: [packId], references: [id], onDelete: SetNull)

  @@index([userId, completedAt])
  @@index([sessionType])
  @@index([packId])
  @@index([anonymized, createdAt])
}

model QuestionReport {
  id               String               @id @default(cuid())
  questionId       String
  question         StudyQuestion        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId           String
  user             User                 @relation("QuestionReportAuthor", fields: [userId], references: [id], onDelete: Cascade)
  reason           QuestionReportReason
  description      String?              @db.Text
  status           QuestionReportStatus @default(OPEN)
  reviewedByUserId String?
  reviewedBy       User?                @relation("QuestionReportReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  reviewNotes      String?              @db.Text
  reportedAt       DateTime             @default(now())
  reviewedAt       DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([questionId, status])
  @@index([userId, reportedAt])
  @@index([status, reportedAt])
  @@map("question_report")
}

model QuestHistory {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  theme         String
  xp            Int
  tasksCount    Int
  taskSnapshot  Json?
  sourceLabText String?
  completedAt   DateTime
  certification String   @default("")
  userName      String   @default("")
  createdAt     DateTime @default(now())
}

model LevelBadge {
  id           String      @id @default(cuid())
  level        Int         @unique
  name         String
  imageUrl     String
  supabasePath String
  userBadges   UserBadge[]
}

model UserBadge {
  id       String     @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime   @default(now())
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    LevelBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
}

model Achievement {
  id               String            @id @default(cuid())
  code             String            @unique
  name             String
  description      String
  rarity           String            @default("common")
  imageUrl         String?
  supabasePath     String?
  generationPrompt String?
  active           Boolean           @default(true)
  displayOrder     Int               @default(0)
  userAchievements UserAchievement[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  progress      Int         @default(0)
  metadata      Json?
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
}

model XpWeightConfig {
  id           String   @id @default(cuid())
  activityType String
  topic        String   @default("*")
  difficulty   String   @default("*")
  multiplier   Float    @default(1)
  bonusXp      Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([activityType, topic, difficulty])
  @@index([activityType, active])
}

model AdminUploadedFile {
  id                    String               @id @default(cuid())
  uploadType            AdminUploadType
  certificationPresetId String?
  certificationPreset   CertificationPreset? @relation(fields: [certificationPresetId], references: [id], onDelete: SetNull)
  uploadedByUserId      String?
  uploadedBy            User?                @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  fileName              String
  mimeType              String
  fileSizeBytes         Int
  storageBucket         String
  storagePath           String
  sha256                String
  source                String               @default("admin")
  metadata              Json?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  ingestionJobs         AdminIngestionJob[]
  generatedQuestions    StudyQuestion[]

  @@unique([storageBucket, storagePath])
  @@index([uploadType, createdAt])
  @@index([certificationPresetId, uploadType, createdAt])
  @@index([uploadedByUserId, createdAt])
  @@index([sha256])
}

model AdminIngestionJob {
  id                    String               @id @default(cuid())
  status                AdminIngestionStatus @default(PENDING)
  uploadType            AdminUploadType
  certificationPresetId String?
  certificationPreset   CertificationPreset? @relation(fields: [certificationPresetId], references: [id], onDelete: SetNull)
  createdByUserId       String?
  createdBy             User?                @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  uploadedFileId        String?
  uploadedFile          AdminUploadedFile?   @relation(fields: [uploadedFileId], references: [id], onDelete: SetNull)
  fileName              String?
  progressPercent       Int                  @default(0)
  message               String?
  desiredCount          Int?
  generatedCount        Int?
  savedCount            Int?
  errorMessage          String?
  startedAt             DateTime?
  finishedAt            DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([status, createdAt])
  @@index([uploadType, createdAt])
  @@index([certificationPresetId, createdAt])
  @@index([createdByUserId, createdAt])
  @@index([uploadedFileId])
}

model AdminEmailTemplate {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  description     String?
  subject         String
  html            String
  text            String?
  active          Boolean  @default(true)
  isSystem        Boolean  @default(false)
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([active, updatedAt])
  @@index([isSystem, updatedAt])
}

// ─── Self-feeding worker models ───────────────────────────────────────────────

enum IngestionSourceStatus {
  PENDING
  FETCHING
  FETCHED
  FAILED
  COMPLETED
}

model IngestionSource {
  id                     String                @id @default(cuid())
  certificationPresetId  String?
  certificationPreset    CertificationPreset?  @relation(fields: [certificationPresetId], references: [id], onDelete: SetNull)
  url                    String                @unique
  displayName            String
  status                 IngestionSourceStatus @default(PENDING)
  lastFetchedAt          DateTime?
  lastFetchSha256        String?
  parsedDomainCount      Int                   @default(0)
  generatedQuestionCount Int                   @default(0)
  errorMessage           String?
  active                 Boolean               @default(true)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  blueprintDomains ExamBlueprintDomain[]

  @@index([status, active])
  @@index([certificationPresetId, status])
}

model ExamBlueprintDomain {
  id                    String              @id @default(cuid())
  certificationPresetId String
  certificationPreset   CertificationPreset @relation(fields: [certificationPresetId], references: [id], onDelete: Cascade)
  ingestionSourceId     String?
  ingestionSource       IngestionSource?    @relation(fields: [ingestionSourceId], references: [id], onDelete: SetNull)
  domainNumber          Int
  domainName            String
  weightPercent         Float
  subTopics             Json?
  active                Boolean             @default(true)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@unique([certificationPresetId, domainNumber])
  @@index([certificationPresetId, active])
}

model QuestionPerformance {
  id                  String        @id @default(cuid())
  questionId          String        @unique
  question            StudyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  totalAttempts       Int           @default(0)
  totalCorrect        Int           @default(0)
  correctRate         Float         @default(0)
  discriminationIndex Float         @default(0)
  reportCount         Int           @default(0)
  lastComputedAt      DateTime?
  flaggedForReview    Boolean       @default(false)
  flagReason          String?
  reviewResult        String?
  reviewedAt          DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([flaggedForReview, lastComputedAt])
  @@index([correctRate])
}

model WeakAreaReport {
  id                    String              @id @default(cuid())
  certificationPresetId String
  certificationPreset   CertificationPreset @relation(fields: [certificationPresetId], references: [id], onDelete: Cascade)
  windowDays            Int                 @default(30)
  sessionsAnalyzed      Int                 @default(0)
  weakAreas             Json
  generationQueued      Boolean             @default(false)
  analyzedAt            DateTime            @default(now())
  createdAt             DateTime            @default(now())

  @@index([certificationPresetId, analyzedAt])
}

model WorkerTrigger {
  id                    String    @id @default(cuid())
  action                String
  source                String    @default("manual") // "manual" | "cron" | "weak_area"
  certificationPresetId String?
  payload               Json?
  processed             Boolean   @default(false)
  processedAt           DateTime?
  createdAt             DateTime  @default(now())

  @@index([processed, createdAt])
  @@index([source, createdAt])
}

model ScheduledJob {
  id          String   @id @default(cuid())
  jobId       String   @unique
  name        String
  description String?
  queue       String
  cronPattern String
  payload     Json?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model UserCertBadge {
  id                    String               @id @default(cuid())
  userId                String
  certificationPresetId String?
  badgeUrl              String
  badgeImageUrl         String?
  earnedAt              DateTime             @default(now())
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificationPreset   CertificationPreset? @relation(fields: [certificationPresetId], references: [id], onDelete: SetNull)
  createdAt             DateTime             @default(now())

  @@index([userId])
}

// ─── Simulado Pack models ─────────────────────────────────────────────────────

model SimuladoPack {
  id                    String               @id @default(cuid())
  name                  String
  certificationPresetId String?
  certificationPreset   CertificationPreset? @relation(fields: [certificationPresetId], references: [id], onDelete: SetNull)
  createdByUserId       String?
  createdBy             User?                @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  questionCount         Int                  @default(65)
  difficultyScore       Int                  @default(1)
  active                Boolean              @default(true)
  artworkUrl            String?
  journeyNarrative      Json?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  questions SimuladoPackQuestion[]
  sessions  StudySessionHistory[]

  @@index([certificationPresetId, active])
  @@index([createdByUserId])
  @@index([active, createdAt])
}

model SimuladoPackQuestion {
  id         String        @id @default(cuid())
  packId     String
  pack       SimuladoPack  @relation(fields: [packId], references: [id], onDelete: Cascade)
  questionId String
  question   StudyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  position   Int

  @@unique([packId, questionId])
  @@unique([packId, position])
  @@index([questionId])
}

// ─── Behavioral email models ──────────────────────────────────────────────────

model UserEmailEvent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  triggerCode String
  subject     String
  sentAt      DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([userId, sentAt])
  @@index([userId, triggerCode, sentAt])
  @@map("user_email_event")
}

model UserBehaviorProfile {
  id                 String    @id @default(cuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  avgAccessHour      Int?
  typicalSessionDays Json?
  churnRiskScore     Float     @default(0)
  streakDays         Int       @default(0)
  lastStreakDate     DateTime?
  dailyFlashcardCap  Int       @default(30)
  lastEmailSentAt    DateTime?
  lastAnalyzedAt     DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("user_behavior_profile")
}

// ─── Phase 1: Retention spine ─────────────────────────────────────────────────

enum FlashcardSource {
  WRONG_ANSWER
  REVIEW_FLAG
  SLOW_ANSWER
  AI_EXPLANATION
  MEMORY_RECOVERY
}

enum FlashcardGrade {
  VERY_HARD
  HARD
  GOOD
  EASY
}

enum AnswerConfidence {
  high
  medium
  low
}

model Flashcard {
  id               String            @id @default(cuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceQuestionId String?
  sourceQuestion   StudyQuestion?    @relation(fields: [sourceQuestionId], references: [id], onDelete: SetNull)
  awsServiceId     String?
  topic            String?
  front            String
  back             String
  hint             String?
  source           FlashcardSource
  // SM-2 scheduling state
  easeFactor       Float             @default(2.5)
  intervalDays     Int               @default(0)
  repetitions      Int               @default(0)
  dueAt            DateTime          @default(now())
  lastReviewedAt   DateTime?
  suspended        Boolean           @default(false)
  reviews          FlashcardReview[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([userId, sourceQuestionId, source])
  @@index([userId, dueAt])
  @@index([userId, suspended, dueAt])
  @@index([sourceQuestionId])
}

model FlashcardReview {
  id           String         @id @default(cuid())
  flashcardId  String
  flashcard    Flashcard      @relation(fields: [flashcardId], references: [id], onDelete: Cascade)
  grade        FlashcardGrade
  prevInterval Int
  newInterval  Int
  reviewedAt   DateTime       @default(now())

  @@index([flashcardId, reviewedAt])
}

model FalseBeliefSignal {
  id               String   @id @default(cuid())
  userId           String
  // LGPD F-05: explicit relation enables onDelete: Cascade so records are
  // automatically removed when the User row is deleted.
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  awsServiceId     String?
  topic            String?
  falseBeliefCount Int      @default(0)
  knownGapCount    Int      @default(0)
  masteryCount     Int      @default(0)
  windowDays       Int      @default(30)
  computedAt       DateTime @default(now())

  @@unique([userId, awsServiceId, topic])
  @@index([userId, computedAt])
}

// ─── Phase 4: Arena (Boss Battles, Weekly Challenge, Daily Quiz) ─────────────

model Boss {
  id               String       @id @default(cuid())
  name             String
  code             String       @unique
  themeService     String // AwsService.code used to source questions
  maxHp            Int
  damagePerCorrect Int          @default(10)
  artworkUrl       String?
  active           Boolean      @default(true)
  battles          BossBattle[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([active])
}

model BossBattle {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bossId      String
  boss        Boss      @relation(fields: [bossId], references: [id], onDelete: Cascade)
  remainingHp Int
  victory     Boolean   @default(false)
  gainedXp    Int       @default(0)
  finishedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, bossId])
  @@index([userId, victory])
}

model WeeklyChallenge {
  id            String                 @id @default(cuid())
  weekStart     DateTime
  weekEnd       DateTime
  active        Boolean                @default(true)
  badgeImageUrl String?
  entries       WeeklyChallengeEntry[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([active, weekStart])
}

model WeeklyChallengeEntry {
  id          String          @id @default(cuid())
  challengeId String
  challenge   WeeklyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  score       Int             @default(0)
  rank        Int?
  gainedXp    Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([challengeId, userId])
  @@index([challengeId, score])
  @@index([userId])
}

model DailyQuiz {
  id          String             @id @default(cuid())
  quizDate    DateTime           @db.Date
  questionIds Json // String[] of StudyQuestion.id
  attempts    DailyQuizAttempt[]
  createdAt   DateTime           @default(now())

  @@unique([quizDate])
  @@index([quizDate])
}

model DailyQuizAttempt {
  id          String    @id @default(cuid())
  quizId      String
  quiz        DailyQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  score       Int       @default(0)
  totalCount  Int       @default(5)
  gainedXp    Int       @default(0)
  completedAt DateTime  @default(now())
  createdAt   DateTime  @default(now())

  @@unique([quizId, userId])
  @@index([userId, completedAt])
}

// ─── Phase 4: News ────────────────────────────────────────────────────────────

model NewsSource {
  id            String     @id @default(cuid())
  name          String
  feedUrl       String     @unique
  category      String     @default("cloud")
  active        Boolean    @default(true)
  lastFetchedAt DateTime?
  items         NewsItem[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([active])
}

model NewsItem {
  id          String     @id @default(cuid())
  sourceId    String
  source      NewsSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  title       String
  url         String
  urlHash     String     @unique // SHA-256 of url for dedup
  summary     String?    @db.Text
  publishedAt DateTime?
  createdAt   DateTime   @default(now())

  @@index([publishedAt])
  @@index([sourceId, publishedAt])
}

// ─── Phase 4: Changelog ───────────────────────────────────────────────────────

// DEF-025 deviation from Blueprint-001 §7 ("githubTag @unique"):
// tagName is intentionally NOT @unique here. Dedup is enforced via githubId @unique,
// which is the GitHub integer release id. GitHub guarantees a unique id per release
// even across re-tags (a re-tag creates a new release with a new id), so the practical
// risk of duplicate tagName rows is limited to the re-tag edge case. Adding a unique
// constraint on tagName would block re-tags from being imported. The changelog display
// (CA-16 "grouped by tag, newest first") uses releasedAt desc ordering, so duplicates
// would appear adjacent and be visible to admins for cleanup. No migration is added.
model ChangelogRelease {
  id           String           @id @default(cuid())
  githubId     Int              @unique // GitHub release integer id — primary dedup key
  tagName      String // Not @unique: see DEF-025 comment above
  name         String?
  bodyMarkdown String?          @db.Text
  adminSummary String?          @db.Text
  highlight    Boolean          @default(false)
  published    Boolean          @default(false)
  releasedAt   DateTime?
  entries      ChangelogEntry[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([published, releasedAt])
}

model ChangelogEntry {
  id        String           @id @default(cuid())
  releaseId String
  release   ChangelogRelease @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  category  String // "fix" | "feature" | "improvement" | "breaking"
  text      String
  createdAt DateTime         @default(now())

  @@index([releaseId])
}

// ─── Phase 3: Instructor Content Library ─────────────────────────────────────

enum LibraryContentType {
  PDF
  IMAGE
  MARKDOWN
  SLIDES
}

model LibraryContent {
  id                    String             @id @default(cuid())
  type                  LibraryContentType
  title                 String
  description           String?
  // Practitioner | SAA | Developer | SysOps | Security | Networking | Database | Serverless
  category              String
  certificationPresetId String?
  awsServiceId          String?
  questChainId          String?
  storageBucket         String?
  storagePath           String?
  bodyMarkdown          String?            @db.Text
  authorName            String
  authorUrl             String?
  authorContact         String?
  published             Boolean            @default(false)
  accessCount           Int                @default(0)
  createdByUserId       String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([published, category])
  @@index([awsServiceId, published])
  @@index([questChainId, published])
}

// ─── Phase 2: Mentor + Quest Chains ──────────────────────────────────────────

model MentorRecommendation {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rank          Int
  // "review_service" | "flashcards" | "sprint" | "kc" | "library"
  actionType    String
  // serviceCode / topic / chainId / contentId
  targetRef     String?
  title         String
  rationale     String
  priorityScore Float
  generatedAt   DateTime @default(now())

  @@index([userId, generatedAt])
}

model QuestChain {
  id                    String            @id @default(cuid())
  certificationPresetId String?
  name                  String
  description           String?
  displayOrder          Int               @default(0)
  active                Boolean           @default(true)
  stages                QuestChainStage[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
}

model QuestChainStage {
  id           String               @id @default(cuid())
  chainId      String
  chain        QuestChain           @relation(fields: [chainId], references: [id], onDelete: Cascade)
  position     Int
  awsServiceId String?
  topic        String?
  title        String
  // e.g. { minScorePercent: 70, sessionType: "KC" }
  unlockRule   Json?
  progress     QuestChainProgress[]
  explain      TrailStageExplain?

  @@unique([chainId, position])
}

model QuestChainProgress {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  stageId     String
  stage       QuestChainStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  completed   Boolean         @default(false)
  completedAt DateTime?

  @@unique([userId, stageId])
  @@index([userId, completed])
}

// Cached AI explanation per stage — generated once, shared across all users.
model TrailStageExplain {
  id        String          @id @default(cuid())
  stageId   String          @unique
  stage     QuestChainStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  markdown  String          @db.Text
  createdAt DateTime        @default(now())

  @@index([stageId])
}
